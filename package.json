{
  "name": "claw-sources",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo - claw-family + futu-openD",
  "scripts": {
    "claw:prod": "cd claw-family && npm run prod",
    "claw:local": "cd claw-family && npm run local",
    "futu": "cd futu-openD && npm run futu",
    "monitor": "cd open-openclaw && npm run monitor",
    "monitor:dev": "cd open-openclaw && npm run monitor:dev",
    "dev": "cd open-openclaw && npm run dev:all",
    "start:all:local": "npm run monitor & npm run claw:local",
    "start:all:prod": "npm run monitor & npm run claw:prod",
    "start:all:local:dev": "npm run monitor:dev & npm run claw:local"
  },
  "keywords": [
    "monorepo",
    "claw-family",
    "futu-openD"
  ],
  "author": "slashhuang",
  "license": "MIT"
}
