# Monorepo workspace
.DS_Store

# External refs - partial ignore
# Note: external-refs/openclaw is tracked as subtree
# Only ignore new external refs that may be added
external-refs/.gitkeep

# Node modules
**/node_modules/

# Python
**/__pycache__/
**/*.pyc
**/*.pyo
**/.env
**/.venv/
**/venv/

# IDE
**/.idea/
**/.vscode/settings.json

# Build artifacts
**/dist/
**/build/
**/*.egg-info/
